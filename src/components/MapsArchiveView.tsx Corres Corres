            background: 'rgba(10, 15, 25, 0.75)', backdropFilter: 'blur(20px)',
            padding: '10px 16px', borderRadius: 16, border: '1px solid rgba(255,255,255,0.08)',
            display: 'flex', alignItems: 'center', gap: 10, pointerEvents: 'auto'
          }}>
            <Navigation size={16} color="#007AFF" fill="#007AFF" />
            <div>
              <div style={{ fontSize: 12, fontWeight: 800 }}>Explore Vietnam</div>
              <div style={{ fontSize: 9, fontWeight: 600, color: 'rgba(255,255,255,0.4)', textTransform: 'uppercase' }}>Memory Hotspots</div>
            </div>
          </div>

          {/* Right: Quick Zoom/Center Controls */}
          <div style={{ display: 'flex', flexDirection: 'column', gap: 10, pointerEvents: 'auto' }}>
            <button style={{
              width: 50, height: 50, background: 'white', borderRadius: 16,
              color: 'black', border: 'none', boxShadow: '0 8px 30px rgba(0,0,0,0.5)',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              cursor: 'pointer'
            }}>
              <Crosshair size={22} />
            </button>
            <button style={{
              width: 50, height: 50, background: 'rgba(20, 25, 40, 0.8)',
              backdropFilter: 'blur(20px)', borderRadius: 16,
              color: 'white', border: '1px solid rgba(255,255,255,0.1)',
              boxShadow: '0 8px 32px rgba(0,0,0,0.4)',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              cursor: 'pointer'
            }}>
              <Maximize2 size={20} />
            </button>
          </div>
        </div>
      </div>

      <style>{`
        @keyframes fadeIn {
          from { opacity: 0; transform: scale(1.05); }
          to { opacity: 1; transform: scale(1); }
        }
        @keyframes pulseLoc {
          0% { box-shadow: 0 0 0 0 rgba(0, 122, 255, 0.7); }
          70% { box-shadow: 0 0 0 15px rgba(0, 122, 255, 0); }
