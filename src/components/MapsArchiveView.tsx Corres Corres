// --- AUTO BOUNDS COMPONENT ---
const MapAutoBounds = ({ historyItems }: { historyItems: HistoryItem[] }) => {
  const map = useMap();

  useEffect(() => {
    if (historyItems.length > 0) {
      const bounds = L.latLngBounds(historyItems.map(item => {
        // Robust coordinate helper
        const lat = 23 - ((item.location?.mapY || 50) / 100) * 15;
        const lng = 102 + ((item.location?.mapX || 50) / 100) * 7;
        return [lat, lng] as L.LatLngExpression;
      }));
      if (bounds.isValid()) {
        map.fitBounds(bounds, { padding: [50, 50], maxZoom: 14, animate: true });
      }
    }
  }, [historyItems, map]);

  return null;
};

interface MapsArchiveViewProps {
  historyItems: HistoryItem[];
  onClose: () => void;
  onViewPhoto?: (item: HistoryItem) => void;
}

const MapsArchiveView = ({ historyItems, onClose, onViewPhoto }: MapsArchiveViewProps) => {
  const [searchQuery, setSearchQuery] = useState('');
  const [activeFilter, setActiveFilter] = useState<'all' | 'recent' | 'travel'>('all');
  
  // Filter coordinates helper
  const getPos = (item: HistoryItem) => {
    const lat = 23 - ((item.location?.mapY || 50) / 100) * 15;
    const lng = 102 + ((item.location?.mapX || 50) / 100) * 7;
    return { lat, lng };
  };

  const photosWithLoc = historyItems.filter(i => i.location && i.image);
  
  // Unique cluster pins logic
  const uniquePins: Array<{ 
    id: string; 
    name: string; 
    pos: { lat: number; lng: number }; 
    items: HistoryItem[];
    mainImage: string;
  }> = [];

  photosWithLoc.forEach(item => {
    const pos = getPos(item);
    const existing = uniquePins.find(p => p.name === item.location?.name);
    if (existing) {
      existing.items.push(item);
    } else {
      uniquePins.push({
        id: item.id,
        name: item.location?.name || 'Unknown',
        pos,
        items: [item],
        mainImage: item.image
      });
    }
  });

  return (
    <div style={{
      position: 'fixed', inset: 0, zIndex: 9000,
      background: '#04070a', display: 'flex', flexDirection: 'column',
      fontFamily: "'Inter', system-ui, sans-serif",
      color: 'white', overflow: 'hidden',
      animation: 'fadeIn 0.35s cubic-bezier(0.16, 1, 0.3, 1)'
    }}>
      {/* 1. Header Navigation */}
      <div style={{
        padding: 'env(safe-area-inset-top) 20px 12px',
        display: 'flex', alignItems: 'center', justifyContent: 'space-between',
        background: 'rgba(10, 15, 25, 0.7)', backdropFilter: 'blur(30px)',
        borderBottom: '1px solid rgba(255,255,255,0.08)',
        zIndex: 10, position: 'relative'
      }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 14 }}>
          <button 
            onClick={onClose}
            style={{
              width: 38, height: 38, borderRadius: 12, border: 'none',
              background: 'rgba(255,255,255,0.08)', color: 'white',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              cursor: 'pointer'
            }}
          >
            <ChevronLeft size={22} strokeWidth={2.5} />
          </button>
          <div>
            <h2 style={{ fontSize: 18, fontWeight: 900, letterSpacing: -0.5, margin: 0 }}>Memory Archive</h2>
            <div style={{ fontSize: 11, fontWeight: 700, color: 'rgba(255,255,255,0.4)', textTransform: 'uppercase', letterSpacing: 0.8, marginTop: -1 }}>
              {photosWithLoc.length} Memories Pinned
            </div>
          </div>
        </div>
        
        <div style={{ display: 'flex', gap: 10 }}>
          <button style={{
            width: 38, height: 38, borderRadius: 12, border: 'none',
            background: 'rgba(255,255,255,0.08)', color: 'white',
            display: 'flex', alignItems: 'center', justifyContent: 'center'
          }}>
            <Calendar size={18} />
          </button>
        </div>
      </div>

      {/* 2. Map Container */}
      <div style={{ flex: 1, position: 'relative', width: '100%' }}>
        <MapContainer 
          center={[15.8, 107.5]} 
          zoom={6} 
          zoomControl={false}
          style={{ height: '100%', width: '100%', background: '#0B1521' }}
        >
          {/* CartoDB Dark Matter Tiles (High Fidelity) */}
          <TileLayer
            url="https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
            attribution='&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
            opacity={0.9}
          />
          
          <MapAutoBounds historyItems={photosWithLoc} />
          
          <ZoomControl position="bottomright" />

          {uniquePins.map(pin => (
            <Marker 
              key={pin.id} 
              position={[pin.pos.lat, pin.pos.lng]} 
              icon={createPhotoIcon(pin.mainImage, pin.items.length)}
              eventHandlers={{
                click: () => onViewPhoto?.(pin.items[0])
              }}
            />
          ))}

          {/* Simulated User Location */}
          <Marker 
            position={[10.7626, 106.6601]} 
            icon={L.divIcon({
              className: 'user-loc-indicator',
              html: `
                <div style="
                  width: 22px; height: 22px; background: #007AFF; border: 3.5px solid #fff;
                  border-radius: 50%; box-shadow: 0 0 20px #007AFF;
                  animation: pulseLoc 2.5s infinite;
                "></div>
              `,
              iconSize: [22, 22],
              iconAnchor: [11, 11]
            })}
          />
        </MapContainer>

        {/* 3. Floating Overlay UI */}
        
        {/* Search Bar */}
        <div style={{
          position: 'absolute', top: 16, left: 16, right: 16,
          zIndex: 400, display: 'flex', gap: 10
        }}>
          <div style={{
            flex: 1, height: 48, background: 'rgba(20, 25, 40, 0.75)',
            backdropFilter: 'blur(20px)', borderRadius: 16,
            border: '1px solid rgba(255,255,255,0.08)',
            display: 'flex', alignItems: 'center', padding: '0 16px',
            boxShadow: '0 8px 32px rgba(0,0,0,0.4)'
          }}>
            <Search size={18} color="rgba(255,255,255,0.4)" strokeWidth={2.5} />
            <input 
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
